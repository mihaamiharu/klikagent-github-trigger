# Server
PORT=3001

# GitHub webhook secret (must match the secret set in GitHub repo settings)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# KlikAgent base URL
KLIKAGENT_URL=http://localhost:3000

# The QA output repo name (where KlikAgent commits specs)
GITHUB_TEST_REPO=klikagent-tests

# QA environment URL passed to KlikAgent as QATask.qaEnvUrl
QA_ENV_URL=https://your-qa-environment.com
